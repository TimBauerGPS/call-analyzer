# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================

# --- Supabase PUBLIC keys (safe for browser — VITE_ prefix) ---
# Supabase Dashboard > Settings > API > Project URL & anon/public key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase SERVICE ROLE key (server-side only — Netlify functions) ---
# Supabase Dashboard > Settings > API > service_role key
# Used by serverless functions to validate user JWTs and fetch per-user API keys.
# NEVER prefix with VITE_ — this must never reach the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- CallRail & OpenAI keys are NOT stored here ---
# Each user enters their own keys in the app's Settings panel.
# They are stored per-user in Supabase and fetched server-side by the
# Netlify functions — never in environment variables.
